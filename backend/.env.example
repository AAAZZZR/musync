APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:3000
APP_URL=http://localhost:3000

# Postgres（Supabase direct connection）
DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# Supabase（JWKS 驗證 ES256 JWT + Storage 上傳）
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
SUPABASE_STORAGE_BUCKET=audio

# ACE-Step 1.5 — RunPod proxy URL
ACE_API_BASE_URL=https://<pod-id>-8002.proxy.runpod.net
ACE_API_KEY=123456
ACE_MODEL=acestep-v15-turbo

# Stripe（訂閱方案）
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_PRO=price_xxx
